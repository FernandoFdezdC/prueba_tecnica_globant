# /etc/mysql/conf.d/my_custom.cnf
[mysqld]
# —————— Fundamentos básicos ——————
user            = mysql
skip-name-resolve           # mejora rendimiento, evita fallos DNS con GRANT @IP :contentReference[oaicite:1]{index=1}
innodb-dedicated-server     = 1   # auto-ajuste para plugins InnoDB :contentReference[oaicite:2]{index=2}

# —————— Memoria y buffers ——————
innodb_buffer_pool_size     = 1G  # asigna ~70‑80 % de RAM disponible :contentReference[oaicite:3]{index=3}
innodb_buffer_pool_instances= 1
innodb_log_buffer_size      = 8M
innodb_flush_log_at_trx_commit = 1     # máxima durabilidad
innodb_flush_method         = O_DIRECT
innodb_io_capacity          = 1000    # ajustable según disco

# —————— Conexiones y límites ——————
max_connections             = 200
thread_cache_size           = 50
table_open_cache            = 2000
table_open_cache_instances  = 16
open_files_limit            = 65535
wait_timeout                = 300
interactive_timeout         = 600

# —————— Logs y diagnóstico ——————
slow_query_log              = ON
slow_query_log_file         = /var/log/mysql/slow.log
long_query_time             = 2        # segundos
log_output                  = FILE

# —————— Internacionalización ——————
character-set-server        = utf8mb4
collation-server            = utf8mb4_unicode_ci
# usa almacenamiento InnoDB por defecto
default-storage-engine      = InnoDB
sql_mode                    = STRICT_TRANS_TABLES,ERROR_FOR_DIVISION_BY_ZERO,NO_ZERO_DATE,NO_ZERO_IN_DATE,ONLY_FULL_GROUP_BY,NO_ENGINE_SUBSTITUTION

# —————— Variables opcionales de seguridad ——————
#max_connect_errors         = 10000
#secure_file_priv           = "/var/lib/mysql-files"